# ── PostgreSQL ──────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=lol
POSTGRES_PASSWORD=lol_secret
POSTGRES_DB=lol_vnext

# Convenience DSN (used by API)
DATABASE_URL=postgresql://lol:lol_secret@localhost:5432/lol_vnext

# ── API ────────────────────────────────────────
API_PORT=3001
API_HOST=0.0.0.0
NODE_ENV=development

# ── Auth / JWT ─────────────────────────────────
JWT_SECRET=dev-secret-change-me-in-production
JWT_EXPIRES_IN=8h

# ── Seed ───────────────────────────────────────
SEED_ADMIN_EMAIL=admin@tlslogistics.us
SEED_ADMIN_PASSWORD=admin123

# ── Web ────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
WEB_PORT=3000
